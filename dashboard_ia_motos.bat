@echo off
title DASHBOARD IA MOTOS
cd /d "%~dp0"
powershell -NoProfile -ExecutionPolicy Bypass -Command "$json='interface\anuncios_encontrados.json'; $total=0; $olx=0; $ml=0; if(Test-Path $json){$dados=Get-Content $json -Raw | ConvertFrom-Json; $total=($dados|Measure-Object).Count; $olx=($dados|Where-Object{$_.origem -match 'OLX'}|Measure-Object).Count; $ml=($dados|Where-Object{$_.origem -match 'Mercado Livre|ML'}|Measure-Object).Count; $info=Get-Item $json; $dt=$info.LastWriteTime.ToString('dd/MM/yyyy HH:mm'); $size=[math]::Round($info.Length/1MB,1)}else{$dt='Arquivo nao encontrado'; $size=0}; $main=Get-CimInstance Win32_Process|Where-Object{$_.Name -eq 'python.exe' -and $_.CommandLine -match 'main.py'}; $flask=Get-CimInstance Win32_Process|Where-Object{$_.Name -eq 'python.exe' -and $_.CommandLine -match 'interface\\app.py'}; $aws=Get-CimInstance Win32_Process|Where-Object{$_.Name -eq 'powershell.exe' -and $_.CommandLine -match 'sincronizar_aws.ps1'}; Write-Host '================================'; Write-Host '        DASHBOARD IA MOTOS'; Write-Host '================================'; Write-Host ('Total anuncios......... '+$total); Write-Host ('OLX.................... '+$olx); Write-Host ('Mercado Livre.......... '+$ml); Write-Host ('Ultima atualizacao..... '+$dt); Write-Host ('Tamanho arquivo........ '+$size+' MB'); Write-Host ''; if($main){Write-Host 'Robo principal......... ONLINE'}else{Write-Host 'Robo principal......... OFFLINE'}; if($flask){Write-Host 'Painel Flask........... ONLINE'}else{Write-Host 'Painel Flask........... OFFLINE'}; if($aws){Write-Host 'Sincronizacao AWS...... ONLINE'}else{Write-Host 'Sincronizacao AWS...... OFFLINE'}; Write-Host '================================'"
pause