@echo off
title DASHBOARD IA MOTOS
cd /d "%~dp0"
powershell -NoProfile -ExecutionPolicy Bypass -Command "$anuncios='interface\anuncios_encontrados.json'; $mlenv='interface\ml_enviados.json'; $total=0; $olx=0; $ml=0; $dt='NAO ENCONTRADO'; $size='0'; if(Test-Path $anuncios){$dados=Get-Content $anuncios -Raw | ConvertFrom-Json; $total=($dados|Measure-Object).Count; $olx=($dados|Where-Object{$_.origem -match 'OLX'}|Measure-Object).Count; $ml=($dados|Where-Object{$_.origem -match 'Mercado Livre|ML'}|Measure-Object).Count; $info=Get-Item $anuncios; $dt=$info.LastWriteTime.ToString('dd/MM/yyyy HH:mm'); $size=[math]::Round($info.Length/1MB,1)}; $mlenvqtd='0'; if(Test-Path $mlenv){try{$mlenvdados=Get-Content $mlenv -Raw | ConvertFrom-Json; if($mlenvdados -is [System.Collections.IEnumerable]){$mlenvqtd=($mlenvdados|Measure-Object).Count}else{$mlenvqtd='0'}}catch{$mlenvqtd='0'}}else{$mlenvqtd='0'}; $main=Get-CimInstance Win32_Process|Where-Object{$_.Name -eq 'python.exe' -and $_.CommandLine -match 'main.py'}; $flask=Get-CimInstance Win32_Process|Where-Object{$_.Name -eq 'python.exe' -and $_.CommandLine -match 'interface\\app.py'}; $aws=Get-CimInstance Win32_Process|Where-Object{$_.Name -eq 'powershell.exe' -and $_.CommandLine -match 'sincronizar_aws.ps1'}; $mainst=if($main){'ONLINE'}else{'OFFLINE'}; $flaskst=if($flask){'ONLINE'}else{'OFFLINE'}; $awsst=if($aws){'ONLINE'}else{'OFFLINE'}; $sist='PARCIAL'; if($mainst -eq 'ONLINE' -and $flaskst -eq 'ONLINE' -and $awsst -eq 'ONLINE'){$sist='ONLINE'}; Write-Host '================================'; Write-Host '       DASHBOARD IA MOTOS'; Write-Host '================================'; Write-Host ''; Write-Host 'ANUNCIOS'; Write-Host ('Total geral............ '+$total); Write-Host ('OLX.................... '+$olx); Write-Host ('Mercado Livre.......... '+$ml); Write-Host ('Telegram ML enviados... '+$mlenvqtd); Write-Host ''; Write-Host 'ARQUIVOS'; Write-Host ('Ultima atualizacao..... '+$dt); Write-Host ('Tamanho arquivo........ '+$size+' MB'); Write-Host ''; Write-Host 'SERVICOS'; Write-Host ('Robo principal......... '+$mainst); Write-Host ('Painel Flask........... '+$flaskst); Write-Host ('Sincronizacao AWS...... '+$awsst); Write-Host ''; Write-Host 'STATUS GERAL'; Write-Host ('Sistema................ '+$sist); Write-Host '================================'"
pause